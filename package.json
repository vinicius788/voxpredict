{
  "name": "voxpredict",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:api": "tsx src/api/server.ts",
    "start": "node --import tsx/esm src/api/server.ts",
    "start:prod": "NODE_ENV=production node --import tsx/esm src/api/server.ts",
    "start:render": "npm run start:prod",
    "build:api": "prisma generate",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "hardhat:compile": "hardhat compile",
    "deploy:mumbai": "npm run hardhat:compile && node scripts/deploy-mumbai.mjs",
    "deploy:amoy": "hardhat run contracts/scripts/deploy.ts --network amoy",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@openzeppelin/contracts": "^5.6.1",
    "@prisma/client": "^5.22.0",
    "@rainbow-me/rainbowkit": "^2.2.10",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "axios": "^1.10.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.3.1",
    "ethers": "^5.8.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.525.0",
    "node-cron": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.5.2",
    "react-router-dom": "^7.6.3",
    "recharts": "^3.1.0",
    "resend": "^6.9.3",
    "siwe": "^3.0.0",
    "viem": "^2.47.0",
    "wagmi": "^2.19.5",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^4.0.5",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@nomicfoundation/hardhat-verify": "^3.0.11",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/react": "^18.2.15",
    "@types/react-dom": "^18.2.7",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.14",
    "eslint": "^8.45.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.3",
    "hardhat": "^3.1.10",
    "postcss": "^8.4.24",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5.0.2",
    "vite": "^7.3.1"
  }
}
