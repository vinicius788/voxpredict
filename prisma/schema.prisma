generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MarketStatus {
  ACTIVE
  CLOSED
  RESOLVED
  CANCELLED
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  BET
  CLAIM
  REFUND
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  walletAddress String?        @unique
  username      String?
  avatarUrl     String?
  role          Role           @default(USER)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  positions     Position[]
  transactions  Transaction[]
  notifications Notification[]
}

model Market {
  id              Int                   @id
  contractAddress String
  question        String
  description     String
  category        String
  endTime         DateTime
  status          MarketStatus          @default(ACTIVE)
  outcome         String?
  totalVolume     Decimal               @default(0)
  totalYes        Decimal               @default(0)
  totalNo         Decimal               @default(0)
  participants    Int                   @default(0)
  token           String                @default("USDT")
  createdAt       DateTime              @default(now())
  resolvedAt      DateTime?
  updatedAt       DateTime              @updatedAt

  probabilityHistory ProbabilitySnapshot[]
  positions          Position[]

  @@index([status, category])
  @@index([endTime])
}

model Position {
  id        String   @id @default(cuid())
  userId    String
  marketId  Int
  side      String
  amount    Decimal
  token     String
  txHash    String   @unique
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([userId, marketId])
  @@index([marketId, side])
}

model ProbabilitySnapshot {
  id        String   @id @default(cuid())
  marketId  Int
  yesProb   Float
  noProb    Float
  volume    Decimal
  timestamp DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, timestamp])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  type      TxType
  amount    Decimal
  token     String
  txHash    String   @unique
  status    String   @default("confirmed")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model Category {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  icon        String   @default("🎯")
  color       String   @default("#7C3AED")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder, active])
}
