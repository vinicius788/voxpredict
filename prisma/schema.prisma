generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum MarketStatus {
  ACTIVE
  CLOSED
  RESOLVED
  CANCELLED
}

enum TxType {
  DEPOSIT
  WITHDRAWAL
  BET
  CLAIM
  REFUND
}

enum ProposalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TemplateFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  walletAddress String?        @unique
  username      String?        @unique
  avatarUrl     String?
  role          Role           @default(USER)
  totalPredictions Int         @default(0)
  correctPredictions Int       @default(0)
  winRate       Float          @default(0)
  totalProfit   Float          @default(0)
  totalVolume   Float          @default(0)
  rank          Int?
  rankChange    Int            @default(0)
  isPublicProfile Boolean      @default(true)
  streak        Int            @default(0)
  badges        String[]       @default([])
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  positions     Position[]
  transactions  Transaction[]
  notifications Notification[]
  proposals     MarketProposal[]
}

model Market {
  id              Int                   @id
  contractAddress String
  question        String
  description     String
  category        String
  endTime         DateTime
  status          MarketStatus          @default(ACTIVE)
  outcome         String?
  totalVolume     Decimal               @default(0)
  totalYes        Decimal               @default(0)
  totalNo         Decimal               @default(0)
  participants    Int                   @default(0)
  token           String                @default("USDT")
  createdAt       DateTime              @default(now())
  resolvedAt      DateTime?
  updatedAt       DateTime              @updatedAt

  probabilityHistory ProbabilitySnapshot[]
  positions          Position[]

  @@index([status, category])
  @@index([endTime])
}

model Position {
  id        String   @id @default(cuid())
  userId    String
  marketId  Int
  side      String
  amount    Decimal
  token     String
  txHash    String   @unique
  claimed   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([userId, marketId])
  @@index([marketId, side])
}

model ProbabilitySnapshot {
  id        String   @id @default(cuid())
  marketId  Int
  yesProb   Float
  noProb    Float
  volume    Decimal
  timestamp DateTime @default(now())

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, timestamp])
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  type      TxType
  amount    Decimal
  token     String
  txHash    String   @unique
  status    String   @default("confirmed")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
}

model Category {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?
  icon        String   @default("🎯")
  color       String   @default("#7C3AED")
  active      Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([sortOrder, active])
}

model MarketProposal {
  id          Int            @id @default(autoincrement())
  title       String
  description String
  category    String
  resolveBy   DateTime
  tags        String[]
  status      ProposalStatus @default(PENDING)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  adminNote   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status, createdAt])
  @@index([userId, createdAt])
}

model MarketTemplate {
  id            Int               @id @default(autoincrement())
  name          String            @unique
  titleTemplate String
  descTemplate  String
  category      String
  frequency     TemplateFrequency
  variables     Json
  minBet        Float             @default(5)
  maxBet        Float             @default(1000)
  active        Boolean           @default(true)
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([active, nextRunAt])
}
